<?xml version="1.0"?>
<robot name="custom_open_manipulator">

  <!-- ===================== LINK 1 ===================== -->
  <link name="link1">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 1 ===================== -->
  <joint name="joint1" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.012 0 0.017" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8" upper="2.8" effort="1" velocity="4.8"/>
  </joint>

  <!-- ===================== LINK 2 ===================== -->
  <link name="link2">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="2e-5" ixy="0" ixz="0"
               iyy="2e-5" iyz="0"
               izz="2e-5"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 2 ===================== -->
  <joint name="joint2" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.0595" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="1.5" effort="1" velocity="4.8"/>
  </joint>

  <!-- ===================== LINK 3 ===================== -->
  <link name="link3">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="3e-4" ixy="0" ixz="0"
               iyy="3e-4" iyz="0"
               izz="6e-5"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 3 ===================== -->
  <joint name="joint3" type="revolute">
    <parent link="link3"/>
    <child link="link7"/>
    <origin xyz="0.024 0 0.128" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.4" effort="1" velocity="4.8"/>
  </joint>

  <!-- ===================== NEW LINK ===================== -->
  <link name="link7">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
  </link>

  <!-- ===================== NEW JOINT (핵심) ===================== -->
  <joint name="joint7" type="revolute">
    <parent link="link7"/>
    <child link="link4"/>


    <origin xyz="0.145 0 0.018" rpy="0.0 0.0 0.0"/>

    <!-- joint1과 동일 -->
    <axis xyz="0 0 1"/>

    <limit lower="-3.1416" upper="3.1416" effort="1" velocity="4.8"/>
  </joint>

  <!-- ===================== LINK 4 ===================== -->
  <link name="link4">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.13"/>
      <inertia ixx="3e-5" ixy="0" ixz="0"
               iyy="2e-4" iyz="0"
               izz="2e-4"/>
    </inertial>
  </link>

  <!-- ===================== JOINT 4 ===================== -->
  <joint name="joint4" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>


    <origin xyz="0.041 0 0" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>
    <limit lower="-1.8" upper="2.0" effort="1" velocity="4.8"/>
  </joint>

  <!-- ===================== LINK 5 ===================== -->
  <link name="link5">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.14"/>
      <inertia ixx="8e-5" ixy="0" ixz="0"
               iyy="7e-5" iyz="0"
               izz="9e-5"/>
    </inertial>
  </link>

  <!-- ===================== END EFFECTOR ===================== -->
  <joint name="end_effector_joint" type="fixed">
    <parent link="link5"/>
    <child link="end_effector"/>
    <origin xyz="0.126 0 0" rpy="0 0 0"/>
  </joint>

  <link name="end_effector">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-3" ixy="0" ixz="0"
               iyy="1e-3" iyz="0"
               izz="1e-3"/>
    </inertial>
  </link>

</robot>
